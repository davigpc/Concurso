<!DOCTYPE html>
<html lang="pt-BR" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Plataforma de estudos interativa para resolução de questões baseada em provas de concursos públicos. Acompanhe seu progresso e melhore seus resultados.">
    <title>PrepConcursos - Plataforma de Resolução de Questões</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

    <!-- Mobile Header bar -->
    <header class="mobile-header">
        <div class="brand-section">
            <div class="brand-logo">P</div>
            <span class="brand-title">PrepConcursos</span>
        </div>
        <button id="menu-toggle-btn" class="menu-toggle-btn" aria-label="Abrir menu">☰</button>
    </header>

    <div class="app-container">
        
        <!-- Sidebar Navigation -->
        <aside class="sidebar">
            <div class="brand-section">
                <div class="brand-logo">P</div>
                <h1 class="brand-title">PrepConcursos</h1>
            </div>
            
            <nav class="sidebar-nav">
                <ul class="nav-menu">
                    <li class="nav-item active">
                        <a href="#dashboard-screen" id="nav-dashboard">
                            <span class="nav-icon">📊</span> Painel de Controle
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#practice-screen" id="nav-practice" onclick="startRandomQuiz()">
                            <span class="nav-icon">✏️</span> Estudar Questões
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#history-screen" id="nav-history">
                            <span class="nav-icon">📜</span> Histórico & Revisão
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#analysis-screen" id="nav-analysis">
                            <span class="nav-icon">📈</span> Análise Detalhada
                        </a>
                    </li>
                    <li class="nav-item">
                        <a href="#settings-screen" id="nav-settings">
                            <span class="nav-icon">⚙️</span> Configurações
                        </a>
                    </li>
                </ul>
            </nav>
            
            <div class="sidebar-footer">
                <button id="theme-toggle-btn" class="theme-toggle-btn">
                    <span class="nav-icon">☀️</span> Modo Claro
                </button>
            </div>
        </aside>

        <!-- Main Workspace Wrapper -->
        <main class="main-wrapper">
            
            <!-- Sticky Header -->
            <header class="main-header">
                <div>
                    <h2 class="font-display" style="font-size: 1.4rem;">Área de Estudos</h2>
                    <p style="font-size: 0.85rem; color: var(--text-secondary);">Bem-vindo de volta! Resolva questões e acompanhe seus dados de aprovação.</p>
                </div>
                <div class="header-user">
                    <div class="user-info" style="text-align: right;">
                        <div style="font-weight: 600; font-size: 0.95rem;">Estudante</div>
                        <div style="font-size: 0.75rem; color: var(--text-secondary);">Perfil Local</div>
                    </div>
                    <div class="user-avatar">E</div>
                </div>
            </header>

            <!-- Content Area -->
            <div class="main-content">

                <!-- 1. DASHBOARD SCREEN -->
                <section id="dashboard-screen" class="app-screen active">
                    <div class="stats-grid">
                        <div class="card card-gradient">
                            <div class="stat-icon">✅</div>
                            <div class="stat-title">Questões Resolvidas</div>
                            <div id="stat-total-solved" class="stat-value">0</div>
                        </div>
                        <div class="card card-gradient">
                            <div class="stat-icon">🎯</div>
                            <div class="stat-title">Taxa de Precisão</div>
                            <div id="stat-accuracy" class="stat-value">0%</div>
                        </div>
                        <div class="card card-gradient">
                            <div class="stat-icon">🏆</div>
                            <div class="stat-title">Total de Acertos</div>
                            <div id="stat-correct" class="stat-value">0</div>
                        </div>
                        <div class="card card-gradient">
                            <div class="stat-icon">⭐</div>
                            <div class="stat-title">Questões Salvas</div>
                            <div id="stat-starred" class="stat-value">0</div>
                        </div>
                    </div>

                    <div class="card" style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem; padding: 1.25rem; background: linear-gradient(135deg, var(--bg-secondary), var(--bg-primary)); border: 1px dashed var(--border-color); border-radius: var(--radius-md); gap: 1rem; flex-wrap: wrap;">
                        <div>
                            <h4 style="margin: 0 0 0.25rem 0; font-size: 1rem; color: var(--text-primary); display: flex; align-items: center; gap: 0.5rem;">📈 Relatório Estatístico e Notas de Corte</h4>
                            <p style="margin: 0; font-size: 0.85rem; color: var(--text-secondary);">Veja o cálculo ponderado da sua nota oficial para a prova da DATAPREV (conforme edital FGV) e comparação com a lista de aprovados.</p>
                        </div>
                        <button class="btn btn-secondary" onclick="switchScreen('analysis-screen')">Ver Análise Detalhada</button>
                    </div>

                    <div style="display: flex; justify-content: space-between; align-items: center; margin-top: 1.5rem;">
                        <h3 class="section-title">Navegar por Concurso</h3>
                        <button id="quick-start-btn" class="btn btn-primary">⚡ Estudo Rápido (Aleatório)</button>
                    </div>

                    <div id="exams-list" class="exams-list">
                        <!-- Exam Cards will be dynamically inserted here -->
                    </div>
                </section>

                <!-- 2. PRACTICE / QUIZ SCREEN -->
                <section id="practice-screen" class="app-screen">
                    <div class="practice-container">
                        
                        <!-- Left Panel: The Question Box -->
                        <div class="quiz-card">
                            <div class="quiz-header">
                                <div class="quiz-meta-info">
                                    <span id="practice-exam-name" style="font-size: 0.85rem; color: var(--text-muted); font-weight: 600;">Exame</span>
                                    <span id="practice-discipline" class="quiz-discipline">Disciplina</span>
                                </div>
                                <div id="quiz-timer" class="timer-box">⏱️ 00:00</div>
                            </div>
                            
                            <div id="question-index-label" style="font-size: 0.9rem; color: var(--text-secondary); font-weight: 600;">Questão X de Y</div>
                            <div id="question-statement" class="question-text">Texto do enunciado...</div>
                            
                            <!-- Options container -->
                            <div id="options-container" class="options-list">
                                <!-- Option Items will be dynamically inserted here -->
                            </div>
                            
                            <div class="quiz-actions">
                                <button id="star-btn" class="btn btn-secondary">☆ Salvar</button>
                                <div style="display: flex; gap: 0.75rem;">
                                    <button id="prev-btn" class="btn btn-secondary">Anterior</button>
                                    <button id="gemini-ai-btn" class="btn btn-secondary" style="display: none; border-color: var(--border-focus); color: var(--border-focus); font-weight: 500;">✨ Explicar com IA</button>
                                    <button id="verify-btn" class="btn btn-primary" disabled>Responder</button>
                                    <button id="next-btn" class="btn btn-secondary">Próxima</button>
                                </div>
                            </div>

                            <!-- Comment/Explanation Box -->
                            <div id="explanation-box" class="explanation-box">
                                <span class="explanation-title">💡 Comentário e Justificativa</span>
                                <p id="explanation-text" class="explanation-content">Explicação detalhada...</p>
                            </div>

                            <!-- AI Explanation Box -->
                            <div id="ai-explanation-box" class="explanation-box" style="display: none; border-left: 3px solid var(--accent-primary); background: linear-gradient(135deg, rgba(99, 102, 241, 0.03), rgba(168, 85, 247, 0.03));">
                                <div style="display: flex; justify-content: space-between; align-items: center; width: 100%; margin-bottom: 0.5rem; flex-wrap: wrap; gap: 0.5rem;">
                                    <span class="explanation-title" style="color: var(--accent-primary); display: flex; align-items: center; gap: 0.5rem; font-weight: 600;">
                                        ✨ Explicação do Gemini AI
                                    </span>
                                    <button id="regenerate-ai-btn" class="btn btn-secondary btn-sm" style="padding: 0.2rem 0.5rem; font-size: 0.75rem; border-color: var(--border-color);">🔄 Recriar Explicação</button>
                                </div>
                                <div id="ai-explanation-text" class="explanation-content" style="line-height: 1.6; white-space: normal;">Carregando explicação do Gemini...</div>
                            </div>
                        </div>

                        <!-- Right Panel: Session Tracker -->
                        <div class="progress-panel">
                            <div class="progress-panel-card">
                                <h3 class="progress-header-title">Status da Sessão</h3>
                                <div class="mini-stats-grid">
                                    <div class="mini-stat-card">
                                        <span style="font-size: 0.8rem; color: var(--text-secondary);">Resolvidas</span>
                                        <span id="practice-solved-stat" class="mini-stat-num">0/0</span>
                                    </div>
                                    <div class="mini-stat-card">
                                        <span style="font-size: 0.8rem; color: var(--text-secondary);">Acertos</span>
                                        <span id="practice-correct-stat" class="mini-stat-num color-correct">0</span>
                                    </div>
                                </div>
                                <div class="mini-stats-grid">
                                    <div class="mini-stat-card">
                                        <span style="font-size: 0.8rem; color: var(--text-secondary);">Erros</span>
                                        <span id="practice-incorrect-stat" class="mini-stat-num color-incorrect">0</span>
                                    </div>
                                    <div class="mini-stat-card">
                                        <span style="font-size: 0.8rem; color: var(--text-secondary);">Meta Diária</span>
                                        <span class="mini-stat-num" style="color: var(--warning);">20</span>
                                    </div>
                                </div>
                            </div>
                        </div>

                    </div>
                </section>

                <!-- 3. HISTORY SCREEN -->
                <section id="history-screen" class="app-screen">
                    <h3 class="section-title">Histórico de Questões</h3>
                    
                    <div class="filters-bar">
                        <div class="filters-group">
                            <span class="filter-label">Filtrar por:</span>
                            <select id="history-exam-filter" class="select-filter" aria-label="Filtrar por Concurso">
                                <option value="all">Todos os Concursos</option>
                            </select>
                            <select id="history-status-filter" class="select-filter" aria-label="Filtrar por Status">
                                <option value="all">Todos os Status</option>
                                <option value="correct">Apenas Acertos</option>
                                <option value="incorrect">Apenas Erros</option>
                            </select>
                        </div>
                    </div>

                    <div id="history-list" class="history-list">
                        <!-- History items will be dynamically inserted here -->
                    </div>
                </section>

                <!-- 4. SETTINGS SCREEN -->
                <section id="settings-screen" class="app-screen">
                    <h3 class="section-title">Configurações Gerais</h3>
                    
                    <div class="card settings-section">
                        <div class="settings-group">
                            <h4>Integração Inteligente (Google AI Studio)</h4>
                            <p class="settings-description">Insira sua chave de API do Gemini para receber explicações detalhadas e personalizadas quando errar ou rever questões.</p>
                            <div style="display: flex; flex-direction: column; gap: 0.5rem; margin-top: 0.5rem; max-width: 500px;">
                                <input type="password" id="gemini-api-key-input" class="select-filter" style="width: 100%; font-family: monospace; padding: 0.6rem 0.75rem;" placeholder="Insira sua API Key (AQ.Ab8RN...)">
                                <button id="save-api-key-btn" class="btn btn-primary" style="align-self: flex-start;">Salvar Chave API</button>
                            </div>
                        </div>
                        
                        <hr style="border: 0; border-top: 1px solid var(--border-color); margin: 1rem 0;">

                        <div class="settings-group">
                            <h4>Limpar Dados de Progresso</h4>
                            <p class="settings-description">Se você deseja reiniciar seus estudos e limpar todo o histórico de questões respondidas, acertos, erros e marcações, utilize o botão abaixo.</p>
                            <button id="reset-data-btn" class="btn btn-danger" style="align-self: flex-start; margin-top: 0.5rem;">Limpar Histórico Local</button>
                        </div>
                        
                        <hr style="border: 0; border-top: 1px solid var(--border-color); margin: 1rem 0;">

                        <div class="settings-group">
                            <h4>Backup do Progresso</h4>
                            <p class="settings-description">Exporte todas as suas respostas, questões salvas e estatísticas para um arquivo no seu computador, ou recupere seu progresso a partir de um backup existente.</p>
                            <div style="display: flex; gap: 0.75rem; margin-top: 0.5rem; flex-wrap: wrap;">
                                <button id="export-backup-btn" class="btn btn-secondary">📥 Exportar Backup</button>
                                <button id="import-backup-btn-trigger" class="btn btn-secondary">📤 Importar Backup</button>
                                <input type="file" id="import-backup-file" accept=".json" style="display: none;">
                            </div>
                        </div>
                        
                        <hr style="border: 0; border-top: 1px solid var(--border-color); margin: 1rem 0;">
                        
                        <div class="settings-group">
                            <h4>Sobre a Aplicação</h4>
                            <p class="settings-description">Esta plataforma foi desenvolvida utilizando tecnologias web modernas para processar e disponibilizar provas de concursos locais, permitindo a prática focada e resoluções com feedbacks e justificativas completas.</p>
                            <p style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.5rem;">Versão 1.0.0 (Estável)</p>
                        </div>
                    </div>
                </section>

                <!-- 5. DETAILED ANALYSIS SCREEN -->
                <section id="analysis-screen" class="app-screen">
                    <h3 class="section-title">Análise de Desempenho</h3>
                    <div id="analysis-container" class="analysis-container">
                        <!-- Loaded dynamically -->
                    </div>
                </section>

            </div>
        </main>
    </div>

    <script src="questions.js"></script>
    <script src="app.js?v=1.0.2"></script>
</body>
</html>
