// Application State
let examsData = [];
let currentExam = null;
let currentQuestions = [];
let currentQuestionIndex = 0;
let selectedOption = null;
let quizTimerInterval = null;
let quizSeconds = 0;

let userState = {
    theme: 'dark',
    completedExams: {}, // examId: completedCount
    solvedQuestions: {}, // questionId: { solved: true, correct: boolean, selectedOption: string, timeSpent: number }
    starredQuestions: {}, // questionId: boolean
    geminiApiKey: '' // default Gemini API Key
};

// Initialize App
document.addEventListener("DOMContentLoaded", () => {
    loadState();
    applyTheme();
    setupRouting();
    setupEventListeners();
    loadQuestions();
});

// Load state from LocalStorage
function loadState() {
    const saved = localStorage.getItem("antigravity_study_state");
    if (saved) {
        try {
            const parsed = JSON.parse(saved);
            userState = { ...userState, ...parsed };
        } catch (e) {
            console.error("Error loading state:", e);
        }
    }
}

// Save state to LocalStorage
function saveState() {
    localStorage.setItem("antigravity_study_state", JSON.stringify(userState));
}

// Apply theme (dark/light)
function applyTheme() {
    document.documentElement.setAttribute("data-theme", userState.theme);
    const themeBtn = document.getElementById("theme-toggle-btn");
    if (themeBtn) {
        themeBtn.innerHTML = userState.theme === 'dark' ? 
            `<span class="nav-icon">☀️</span> Modo Claro` : 
            `<span class="nav-icon">🌙</span> Modo Escuro`;
    }
}

// Toggle Theme
function toggleTheme() {
    userState.theme = userState.theme === 'dark' ? 'light' : 'dark';
    applyTheme();
    saveState();
}

// Setup simple Router
function setupRouting() {
    const navLinks = document.querySelectorAll(".nav-item a");
    navLinks.forEach(link => {
        link.addEventListener("click", (e) => {
            e.preventDefault();
            const targetId = link.getAttribute("href").substring(1);
            switchScreen(targetId);
            
            // Close mobile menu if open
            const sidebar = document.querySelector(".sidebar");
            if (sidebar) sidebar.classList.remove("open");
        });
    });
}

function switchScreen(screenId) {
    // Stop quiz timer if we move away from practice
    if (screenId !== 'practice-screen') {
        stopQuizTimer();
    }

    // Toggle active classes on screens
    document.querySelectorAll(".app-screen").forEach(screen => {
        screen.classList.remove("active");
    });
    const targetScreen = document.getElementById(screenId);
    if (targetScreen) targetScreen.classList.add("active");

    // Toggle active menu class
    document.querySelectorAll(".nav-item").forEach(item => {
        item.classList.remove("active");
        const link = item.querySelector("a");
        if (link && link.getAttribute("href") === `#${screenId}`) {
            item.classList.add("active");
        }
    });

    // Render screen specific content
    if (screenId === 'dashboard-screen') {
        renderDashboard();
    } else if (screenId === 'history-screen') {
        renderHistory();
    } else if (screenId === 'settings-screen') {
        renderSettings();
    } else if (screenId === 'analysis-screen') {
        renderAnalysis();
    }
}
window.switchScreen = switchScreen;

// Setup core event handlers
function setupEventListeners() {
    // Theme toggle click
    const themeBtn = document.getElementById("theme-toggle-btn");
    if (themeBtn) {
        themeBtn.addEventListener("click", toggleTheme);
    }

    // Mobile sidebar toggle
    const menuToggle = document.getElementById("menu-toggle-btn");
    if (menuToggle) {
        menuToggle.addEventListener("click", () => {
            const sidebar = document.querySelector(".sidebar");
            if (sidebar) sidebar.classList.toggle("open");
        });
    }

    // Quiz action buttons
    document.getElementById("verify-btn").addEventListener("click", verifyAnswer);
    document.getElementById("prev-btn").addEventListener("click", prevQuestion);
    document.getElementById("next-btn").addEventListener("click", nextQuestion);
    document.getElementById("star-btn").addEventListener("click", toggleStarCurrentQuestion);
    
    // Quick Study button
    document.getElementById("quick-start-btn").addEventListener("click", startRandomQuiz);

    // Filters for history view
    document.getElementById("history-exam-filter").addEventListener("change", renderHistory);
    document.getElementById("history-status-filter").addEventListener("change", renderHistory);

    // Settings actions
    document.getElementById("reset-data-btn").addEventListener("click", resetAppData);

    // Backup actions
    const exportBtn = document.getElementById("export-backup-btn");
    if (exportBtn) {
        exportBtn.addEventListener("click", exportBackup);
    }
    const importTriggerBtn = document.getElementById("import-backup-btn-trigger");
    const importFileInput = document.getElementById("import-backup-file");
    if (importTriggerBtn && importFileInput) {
        importTriggerBtn.addEventListener("click", () => importFileInput.click());
        importFileInput.addEventListener("change", importBackup);
    }

    // Gemini AI button clicks
    const geminiBtn = document.getElementById("gemini-ai-btn");
    if (geminiBtn) {
        geminiBtn.addEventListener("click", () => triggerGeminiExplanation());
    }
    const regenBtn = document.getElementById("regenerate-ai-btn");
    if (regenBtn) {
        regenBtn.addEventListener("click", () => triggerGeminiExplanation(true));
    }
    const saveApiKeyBtn = document.getElementById("save-api-key-btn");
    if (saveApiKeyBtn) {
        saveApiKeyBtn.addEventListener("click", saveGeminiApiKey);
    }
}

// Load Questions from JSON / Local Variable
function loadQuestions() {
    if (typeof EXAMS_DATA !== 'undefined' && Array.isArray(EXAMS_DATA)) {
        examsData = EXAMS_DATA;
        renderDashboard();
        populateHistoryFilters();
        console.log("Banco de questões carregado com sucesso a partir de questions.js (modo local/file://)");
    } else {
        fetch("questions.json")
            .then(res => res.json())
            .then(data => {
                examsData = data;
                renderDashboard();
                populateHistoryFilters();
                console.log("Banco de questões carregado com sucesso via fetch do questions.json");
            })
            .catch(err => {
                console.error("Error loading questions.json:", err);
                alert("Erro ao carregar o banco de dados de questões. Por favor, verifique se questions.json ou questions.js existe.");
            });
    }
}

// Populates filters inside History page dynamically
function populateHistoryFilters() {
    const examFilter = document.getElementById("history-exam-filter");
    if (!examFilter) return;
    
    // Reset but keep first 'All' option
    examFilter.innerHTML = '<option value="all">Todos os Concursos</option>';
    
    examsData.forEach(exam => {
        const opt = document.createElement("option");
        opt.value = exam.exam_id;
        opt.textContent = exam.exam_name;
        examFilter.appendChild(opt);
    });
}

// Dashboard view rendering
function renderDashboard() {
    // Compute stats
    let totalQuestions = 0;
    let solvedCount = 0;
    let correctCount = 0;
    let incorrectCount = 0;
    let starredCount = Object.keys(userState.starredQuestions).filter(k => userState.starredQuestions[k]).length;

    examsData.forEach(exam => {
        exam.questions.forEach(q => {
            totalQuestions++;
            const state = userState.solvedQuestions[q.id];
            if (state && state.solved) {
                solvedCount++;
                if (state.correct) correctCount++;
                else incorrectCount++;
            }
        });
    });

    const accuracy = solvedCount > 0 ? Math.round((correctCount / solvedCount) * 100) : 0;

    // Update UI numbers
    document.getElementById("stat-total-solved").textContent = solvedCount;
    document.getElementById("stat-accuracy").textContent = `${accuracy}%`;
    document.getElementById("stat-correct").textContent = correctCount;
    document.getElementById("stat-starred").textContent = starredCount;

    // Render exam cards list
    const examsListEl = document.getElementById("exams-list");
    if (!examsListEl) return;

    examsListEl.innerHTML = "";
    
    examsData.forEach(exam => {
        const totalExamQuestions = exam.questions.length;
        let examSolved = 0;
        
        exam.questions.forEach(q => {
            if (userState.solvedQuestions[q.id]?.solved) {
                examSolved++;
            }
        });

        const progressPercent = Math.round((examSolved / totalExamQuestions) * 100) || 0;

        const card = document.createElement("div");
        card.className = "exam-card";
        card.innerHTML = `
            <div class="exam-header">
                <span class="exam-badge">${exam.banca}</span>
            </div>
            <h3 class="exam-title">${exam.exam_name}</h3>
            <div class="exam-meta">
                <span>${totalExamQuestions} Questões</span>
                <span>Resolvidas: ${examSolved}/${totalExamQuestions}</span>
            </div>
            <div class="exam-progress">
                <div class="progress-bar-container">
                    <div class="progress-bar" style="width: ${progressPercent}%"></div>
                </div>
                <div style="font-size: 0.8rem; text-align: right; color: var(--text-secondary);">${progressPercent}% Concluído</div>
            </div>
            <button class="exam-btn" onclick="startExam('${exam.exam_id}')">Estudar Agora</button>
        `;
        examsListEl.appendChild(card);
    });
}

// Start exam study session
window.startExam = function(examId) {
    const exam = examsData.find(e => e.exam_id === examId);
    if (!exam) return;

    currentExam = exam;
    currentQuestions = exam.questions;
    currentQuestionIndex = 0;
    
    startQuizTimer();
    switchScreen('practice-screen');
    renderQuestion();
};

// Start a random practice set
function startRandomQuiz() {
    // Get all unresolved questions across all exams
    let pool = [];
    examsData.forEach(exam => {
        exam.questions.forEach(q => {
            if (!userState.solvedQuestions[q.id]?.solved) {
                pool.push({ ...q, examName: exam.exam_name });
            }
        });
    });

    if (pool.length === 0) {
        // If all resolved, just offer all questions
        examsData.forEach(exam => {
            exam.questions.forEach(q => {
                pool.push({ ...q, examName: exam.exam_name });
            });
        });
    }

    // Shuffle pool and take 20 questions
    pool.sort(() => 0.5 - Math.random());
    currentQuestions = pool.slice(0, 20);
    currentExam = { exam_id: "random_quiz", exam_name: "Estudo Rápido (Personalizado)", questions: currentQuestions };
    currentQuestionIndex = 0;

    startQuizTimer();
    switchScreen('practice-screen');
    renderQuestion();
}

// Timer management
function startQuizTimer() {
    stopQuizTimer();
    quizSeconds = 0;
    updateTimerDisplay();
    quizTimerInterval = setInterval(() => {
        quizSeconds++;
        updateTimerDisplay();
    }, 1000);
}

function stopQuizTimer() {
    if (quizTimerInterval) {
        clearInterval(quizTimerInterval);
        quizTimerInterval = null;
    }
}

function updateTimerDisplay() {
    const mins = Math.floor(quizSeconds / 60).toString().padStart(2, '0');
    const secs = (quizSeconds % 60).toString().padStart(2, '0');
    const timerBox = document.getElementById("quiz-timer");
    if (timerBox) {
        timerBox.textContent = `⏱️ ${mins}:${secs}`;
    }
}

// Render the active question in practice screen
function renderQuestion() {
    if (currentQuestions.length === 0) return;

    const q = currentQuestions[currentQuestionIndex];
    selectedOption = null;

    // Set panel info
    document.getElementById("practice-exam-name").textContent = currentExam.exam_name;
    document.getElementById("practice-discipline").textContent = q.discipline;
    document.getElementById("question-index-label").textContent = `Questão ${currentQuestionIndex + 1} de ${currentQuestions.length}`;

    // Question statement
    document.getElementById("question-statement").innerHTML = q.statement.replace(/\n/g, "<br>");

    // Render options list
    const optionsContainer = document.getElementById("options-container");
    optionsContainer.innerHTML = "";

    const isSolved = !!userState.solvedQuestions[q.id]?.solved;
    const solvedData = userState.solvedQuestions[q.id];

    Object.entries(q.options).forEach(([key, val]) => {
        const item = document.createElement("div");
        item.className = "option-item";
        item.dataset.option = key;
        
        let extraClass = "";
        if (isSolved) {
            if (key === q.correct_answer) {
                extraClass = "correct";
            } else if (key === solvedData?.selectedOption) {
                extraClass = "incorrect";
            }
        } else {
            item.addEventListener("click", () => selectOption(key));
        }

        if (extraClass) item.classList.add(extraClass);

        item.innerHTML = `
            <span class="option-badge">${key}</span>
            <span class="option-text">${val}</span>
        `;
        optionsContainer.appendChild(item);
    });

    // Toggle button visibilities
    const verifyBtn = document.getElementById("verify-btn");
    const explanationBox = document.getElementById("explanation-box");
    const geminiAiBtn = document.getElementById("gemini-ai-btn");
    const aiExplanationBox = document.getElementById("ai-explanation-box");
    const aiExplanationText = document.getElementById("ai-explanation-text");

    if (isSolved) {
        verifyBtn.disabled = true;
        verifyBtn.textContent = "Verificado";
        explanationBox.style.display = "flex";
        document.getElementById("explanation-text").innerHTML = q.explanation.replace(/\n/g, "<br>");
        
        // Gemini AI button display
        if (geminiAiBtn) {
            geminiAiBtn.style.display = "inline-flex";
            geminiAiBtn.textContent = solvedData.aiExplanation ? "✨ Ver Explicação IA" : "✨ Explicar com IA";
        }
        
        // Gemini AI explanation box display
        if (aiExplanationBox && aiExplanationText) {
            if (solvedData.aiExplanation) {
                aiExplanationBox.style.display = "flex";
                aiExplanationText.innerHTML = solvedData.aiExplanation;
            } else {
                aiExplanationBox.style.display = "none";
            }
        }
    } else {
        verifyBtn.disabled = true;
        verifyBtn.textContent = "Responder";
        explanationBox.style.display = "none";
        
        if (geminiAiBtn) geminiAiBtn.style.display = "none";
        if (aiExplanationBox) aiExplanationBox.style.display = "none";
    }

    // Navigation buttons
    document.getElementById("prev-btn").disabled = currentQuestionIndex === 0;
    document.getElementById("next-btn").textContent = currentQuestionIndex === currentQuestions.length - 1 ? "Finalizar" : "Próxima";

    // Star icon state
    updateStarButtonState(q.id);
    
    // Update active practice side indicators
    updatePracticeSidePanel();
}

function updateStarButtonState(qId) {
    const starBtn = document.getElementById("star-btn");
    if (!starBtn) return;
    if (userState.starredQuestions[qId]) {
        starBtn.innerHTML = "⭐ Salvo";
        starBtn.classList.add("btn-secondary");
    } else {
        starBtn.innerHTML = "☆ Salvar";
        starBtn.classList.remove("btn-secondary");
    }
}

function updatePracticeSidePanel() {
    let total = currentQuestions.length;
    let correct = 0;
    let incorrect = 0;
    let solved = 0;

    currentQuestions.forEach(q => {
        const state = userState.solvedQuestions[q.id];
        if (state && state.solved) {
            solved++;
            if (state.correct) correct++;
            else incorrect++;
        }
    });

    document.getElementById("practice-solved-stat").textContent = `${solved}/${total}`;
    document.getElementById("practice-correct-stat").textContent = correct;
    document.getElementById("practice-incorrect-stat").textContent = incorrect;
}

// Option item click
function selectOption(optionChar) {
    const q = currentQuestions[currentQuestionIndex];
    if (userState.solvedQuestions[q.id]?.solved) return; // already solved

    selectedOption = optionChar;
    
    // Toggle active state classes on options
    document.querySelectorAll(".option-item").forEach(item => {
        item.classList.remove("selected");
        if (item.dataset.option === optionChar) {
            item.classList.add("selected");
        }
    });

    // Enable verify button
    const verifyBtn = document.getElementById("verify-btn");
    verifyBtn.disabled = false;
}

// Answer verification action
function verifyAnswer() {
    if (!selectedOption) return;

    const q = currentQuestions[currentQuestionIndex];
    const isCorrect = selectedOption === q.correct_answer;

    // Save answer state
    userState.solvedQuestions[q.id] = {
        solved: true,
        correct: isCorrect,
        selectedOption: selectedOption,
        timeSpent: quizSeconds
    };
    saveState();

    // Rerender question to trigger explanation and styling states
    renderQuestion();
}

// Star current question
function toggleStarCurrentQuestion() {
    if (currentQuestions.length === 0) return;
    const q = currentQuestions[currentQuestionIndex];
    
    userState.starredQuestions[q.id] = !userState.starredQuestions[q.id];
    saveState();
    updateStarButtonState(q.id);
}

// Next/prev question navigations
function prevQuestion() {
    if (currentQuestionIndex > 0) {
        currentQuestionIndex--;
        renderQuestion();
    }
}

function nextQuestion() {
    if (currentQuestionIndex < currentQuestions.length - 1) {
        currentQuestionIndex++;
        renderQuestion();
        // Reset timer count for new question
        quizSeconds = 0;
    } else {
        // Exam/set complete
        stopQuizTimer();
        alert("Você completou esta sessão de estudos! Excelente trabalho.");
        switchScreen('dashboard-screen');
    }
}

// History page rendering
function renderHistory() {
    const listEl = document.getElementById("history-list");
    if (!listEl) return;

    listEl.innerHTML = "";

    const examFilter = document.getElementById("history-exam-filter").value;
    const statusFilter = document.getElementById("history-status-filter").value;

    let itemsToRender = [];

    examsData.forEach(exam => {
        // filter by exam
        if (examFilter !== 'all' && exam.exam_id !== examFilter) return;

        exam.questions.forEach(q => {
            const state = userState.solvedQuestions[q.id];
            
            // Filter by solved state
            if (!state || !state.solved) return;
            
            // Filter by correct/incorrect status
            if (statusFilter === 'correct' && !state.correct) return;
            if (statusFilter === 'incorrect' && state.correct) return;

            itemsToRender.push({
                question: q,
                exam: exam,
                state: state
            });
        });
    });

    if (itemsToRender.length === 0) {
        listEl.innerHTML = `<div class="card" style="text-align: center; color: var(--text-secondary); padding: 3rem;">Nenhuma questão encontrada nos filtros. Resolva questões para popular seu histórico!</div>`;
        return;
    }

    itemsToRender.forEach(item => {
        const itemEl = document.createElement("div");
        itemEl.className = "history-item";
        
        const statusBadgeClass = item.state.correct ? "badge-correct" : "badge-incorrect";
        const statusIcon = item.state.correct ? "✓" : "✗";

        const plainStatement = item.question.statement.replace(/<[^>]*>/g, "");
        const previewText = plainStatement.length > 140 ? plainStatement.substring(0, 140) + "..." : plainStatement;
        itemEl.innerHTML = `
            <div class="history-status-badge ${statusBadgeClass}">${statusIcon}</div>
            <div class="history-details">
                <span class="history-exam-name">${item.exam.exam_name}</span>
                <p class="history-question-preview">Q${item.question.number}: ${previewText}</p>
                <div class="history-meta">
                    <span>Assunto: ${item.question.discipline}</span> | 
                    <span>Resposta: (${item.state.selectedOption})</span> | 
                    <span>Tempo: ${item.state.timeSpent}s</span>
                </div>
            </div>
            <div class="history-actions">
                <button class="btn btn-secondary" onclick="reviewHistoryQuestion('${item.exam.exam_id}', ${item.question.number})">Rever</button>
            </div>
        `;
        listEl.appendChild(itemEl);
    });
}

window.reviewHistoryQuestion = function(examId, questionNum) {
    const exam = examsData.find(e => e.exam_id === examId);
    if (!exam) return;

    currentExam = exam;
    currentQuestions = exam.questions;
    currentQuestionIndex = currentQuestions.findIndex(q => q.number === questionNum);

    if (currentQuestionIndex === -1) currentQuestionIndex = 0;
    
    stopQuizTimer();
    switchScreen('practice-screen');
    renderQuestion();
};

// Settings screen rendering
function renderSettings() {
    const keyInput = document.getElementById("gemini-api-key-input");
    if (keyInput) {
        keyInput.value = userState.geminiApiKey || "";
    }
}

function saveGeminiApiKey() {
    const keyInput = document.getElementById("gemini-api-key-input");
    if (keyInput) {
        userState.geminiApiKey = keyInput.value.trim();
        saveState();
        alert("Chave de API do Gemini salva com sucesso!");
    }
}

// Reset app progress
function resetAppData() {
    if (confirm("Tem certeza de que deseja apagar todo o seu progresso de estudos, histórico de questões e estatísticas? Esta ação não pode ser desfeita.")) {
        userState.solvedQuestions = {};
        userState.starredQuestions = {};
        userState.completedExams = {};
        saveState();
        alert("Todos os dados de progresso foram apagados!");
        switchScreen('dashboard-screen');
    }
}

// Export current state as JSON file
function exportBackup() {
    try {
        const dataStr = JSON.stringify(userState, null, 2);
        const dataUri = 'data:application/json;charset=utf-8,'+ encodeURIComponent(dataStr);
        
        const exportFileDefaultName = `prepconcursos_backup_${new Date().toISOString().slice(0,10)}.json`;
        
        const linkElement = document.createElement('a');
        linkElement.setAttribute('href', dataUri);
        linkElement.setAttribute('download', exportFileDefaultName);
        linkElement.click();
    } catch (e) {
        console.error("Erro ao exportar backup:", e);
        alert("Erro ao gerar o arquivo de backup.");
    }
}

// Import state from JSON file
function importBackup(e) {
    const fileReader = new FileReader();
    const file = e.target.files[0];
    if (!file) return;

    fileReader.onload = function(event) {
        try {
            const parsed = JSON.parse(event.target.result);
            
            // Basic validation of import structure
            if (parsed && (parsed.solvedQuestions || parsed.starredQuestions)) {
                if (confirm("Deseja substituir seu progresso atual pelo progresso contido neste arquivo de backup?")) {
                    userState = {
                        theme: parsed.theme || userState.theme,
                        completedExams: parsed.completedExams || {},
                        solvedQuestions: parsed.solvedQuestions || {},
                        starredQuestions: parsed.starredQuestions || {}
                    };
                    saveState();
                    alert("Backup restaurado com sucesso!");
                    // Refresh view
                    switchScreen('dashboard-screen');
                    // Reset file input value so same file can be selected again if needed
                    e.target.value = "";
                }
            } else {
                alert("O arquivo selecionado não parece ser um backup válido do PrepConcursos.");
            }
        } catch (error) {
            console.error("Erro ao importar backup:", error);
            alert("Erro ao ler o arquivo de backup. Verifique se é um arquivo JSON válido.");
        }
    };
    fileReader.readAsText(file);
}

// Render the Detailed Performance Analysis screen
function renderAnalysis() {
    const container = document.getElementById("analysis-container");
    if (!container) return;

    container.innerHTML = "";

    // 1. Gather all questions and index them
    const qMap = {};
    const examMap = {};
    
    examsData.forEach(exam => {
        examMap[exam.exam_id] = {
            name: exam.exam_name,
            banca: exam.banca,
            total: 0,
            correct: 0,
            time: 0
        };
        exam.questions.forEach(q => {
            qMap[q.id] = {
                examId: exam.exam_id,
                examName: exam.exam_name,
                banca: exam.banca,
                discipline: q.discipline,
                number: q.number,
                correctAnswer: q.correct_answer,
                statement: q.statement
            };
        });
    });

    const solved = userState.solvedQuestions;
    let totalSolved = 0;
    let correctCount = 0;
    let incorrectCount = 0;
    let totalTime = 0;

    const disciplines = {};
    const exams = {};
    const incorrectDetails = [];

    Object.entries(solved).forEach(([qId, info]) => {
        if (!info.solved) return;

        totalSolved++;
        const isCorrect = info.correct;
        const timeSpent = info.timeSpent || 0;
        totalTime += timeSpent;

        if (isCorrect) correctCount++;
        else incorrectCount++;

        const qDetails = qMap[qId] || {
            examId: "unknown",
            examName: "Desconhecido",
            banca: "Desconhecido",
            discipline: "Desconhecido",
            number: 0,
            correctAnswer: "",
            statement: ""
        };

        const disc = qDetails.discipline;
        const examId = qDetails.examId;

        // Group by discipline
        if (!disciplines[disc]) {
            disciplines[disc] = { total: 0, correct: 0, time: 0 };
        }
        disciplines[disc].total++;
        disciplines[disc].time += timeSpent;
        if (isCorrect) disciplines[disc].correct++;

        // Group by exam
        if (!exams[examId]) {
            exams[examId] = { name: qDetails.examName, banca: qDetails.banca, total: 0, correct: 0, time: 0 };
        }
        exams[examId].total++;
        exams[examId].time += timeSpent;
        if (isCorrect) exams[examId].correct++;

        if (!isCorrect) {
            incorrectDetails.push({
                id: qId,
                number: qDetails.number,
                discipline: disc,
                examId: examId,
                examName: qDetails.examName,
                statement: qDetails.statement,
                selected: info.selectedOption,
                correctAnswer: qDetails.correctAnswer,
                time: timeSpent
            });
        }
    });

    if (totalSolved === 0) {
        container.innerHTML = `
            <div class="card" style="text-align: center; color: var(--text-secondary); padding: 4rem;">
                <span style="font-size: 3rem; display: block; margin-bottom: 1rem;">📈</span>
                <h3>Nenhum dado de desempenho encontrado</h3>
                <p style="margin-top: 0.5rem; max-width: 500px; margin-left: auto; margin-right: auto;">Comece a resolver questões nos simulados para visualizar aqui suas notas, pontos fortes, fracos e a estimativa de aprovação.</p>
                <button class="btn btn-primary" style="margin-top: 1.5rem;" onclick="startRandomQuiz()">Iniciar Estudo Rápido</button>
            </div>
        `;
        return;
    }

    const accuracy = totalSolved > 0 ? (correctCount / totalSolved * 100) : 0;
    const avgTime = totalSolved > 0 ? (totalTime / totalSolved) : 0;

    const hours = Math.floor(totalTime / 3600);
    const minutes = Math.floor((totalTime % 3600) / 60);
    const seconds = totalTime % 60;
    const timeStr = hours > 0 ? `${hours}h ${minutes}m ${seconds}s` : `${minutes}m ${seconds}s`;

    // 2. Calculate official Dataprev score if they solved questions from that exam
    let dataprevHtml = "";
    const dpExamId = "ati-arquitetura-engenharia-e-sustentacao-tecnologica-cns002-tipo-01";
    const dpExamState = exams[dpExamId];
    if (dpExamState) {
        let cgCorrect = 0;
        let cgTotal = 0;
        let ceCorrect = 0;
        let ceTotal = 0;

        const dpExam = examsData.find(e => e.exam_id === dpExamId);
        if (dpExam) {
            dpExam.questions.forEach(q => {
                const isCorrect = solved[q.id]?.correct || false;
                if (q.number <= 40) {
                    cgTotal++;
                    if (isCorrect) cgCorrect++;
                } else {
                    ceTotal++;
                    if (isCorrect) ceCorrect++;
                }
            });
        }

        const dpScore = (cgCorrect * 1.0) + (ceCorrect * 2.5);
        const dpMax = (cgTotal * 1.0) + (ceTotal * 2.5);
        const dpPercent = (dpScore / dpMax * 100).toFixed(1);
        const dpPassed = dpScore >= 57.5;
        
        let statusBadge = dpPassed ? 
            `<span class="badge badge-success">🟢 APROVADO NO SIMULADO (Pontuação: ${dpScore.toFixed(1)} / ${dpMax.toFixed(1)})</span>` : 
            `<span class="badge badge-danger">🔴 DESCLASSIFICADO NO SIMULADO (Pontuação: ${dpScore.toFixed(1)} / ${dpMax.toFixed(1)})</span>`;

        let statusText = dpPassed ?
            `Sua nota de <strong>${dpScore.toFixed(1)} pontos</strong> ficou acima da pontuação de corte mínima do edital (<strong>57.5 pontos</strong>). Parabéns! Continue praticando para consolidar sua vaga.` :
            `Sua nota de <strong>${dpScore.toFixed(1)} pontos</strong> ficou abaixo da pontuação de corte mínima do edital (<strong>57.5 pontos</strong>). Faltam apenas <strong>${(57.5 - dpScore).toFixed(1)} pontos</strong>. Reforce o estudo das matérias com menor precisão!`;

        dataprevHtml = `
            <div class="card analysis-card highlight-card" style="margin-top: 1.5rem;">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; flex-wrap: wrap; gap: 1.5rem;">
                    <div style="flex: 1; min-width: 280px;">
                        <h4 style="font-size: 1.15rem; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem; color: var(--text-primary);">
                            🎯 Estimativa de Nota Oficial - DATAPREV 2024
                        </h4>
                        <p style="font-size: 0.9rem; color: var(--text-secondary); line-height: 1.5; margin-bottom: 1rem;">
                            ${statusText}
                        </p>
                        <div style="display: flex; gap: 1.5rem; flex-wrap: wrap;">
                            <div>
                                <span style="font-size: 0.8rem; color: var(--text-muted); display: block;">Conhecimentos Gerais (Peso 1.0)</span>
                                <strong style="font-size: 1.1rem; color: var(--text-primary);">${cgCorrect} / ${cgTotal} acertos (${cgCorrect * 1.0} pts)</strong>
                            </div>
                            <div>
                                <span style="font-size: 0.8rem; color: var(--text-muted); display: block;">Conhecimentos Específicos (Peso 2.5)</span>
                                <strong style="font-size: 1.1rem; color: var(--text-primary);">${ceCorrect} / ${ceTotal} acertos (${(ceCorrect * 2.5).toFixed(1)} pts)</strong>
                            </div>
                        </div>
                    </div>
                    <div style="text-align: center; min-width: 180px; align-self: center; display: flex; flex-direction: column; align-items: center;">
                        <div class="score-radial-progress">
                            <span class="score-number">${dpScore.toFixed(1)}</span>
                            <span class="score-max">/ ${dpMax} pts</span>
                        </div>
                        <div style="margin-top: 0.75rem;">
                            ${statusBadge}
                        </div>
                    </div>
                </div>
            </div>
        `;
    }

    // 3. Strengths and Weaknesses
    let bestDisc = "";
    let bestAcc = -1;
    let worstDisc = "";
    let worstAcc = 101;

    Object.entries(disciplines).forEach(([disc, stat]) => {
        const acc = stat.correct / stat.total * 100;
        if (stat.total >= 2) {
            if (acc > bestAcc) {
                bestAcc = acc;
                bestDisc = disc;
            }
            if (acc < worstAcc) {
                worstAcc = acc;
                worstDisc = disc;
            }
        }
    });

    let strengthsHtml = "";
    if (bestDisc || worstDisc) {
        strengthsHtml = `
            <div class="analysis-grid-two" style="margin-top: 1.5rem;">
                <div class="card analysis-card">
                    <h4 style="color: var(--success); display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
                        <span>🟢</span> Ponto Forte
                    </h4>
                    ${bestDisc ? `
                        <p style="font-size: 0.95rem; font-weight: 600; color: var(--text-primary);">${bestDisc}</p>
                        <p style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem;">Aproveitamento excelente de <strong>${bestAcc.toFixed(1)}%</strong>. Você está dominando este assunto!</p>
                    ` : '<p style="font-size: 0.85rem; color: var(--text-secondary);">Resolva mais questões de cada disciplina para identificar seu ponto forte.</p>'}
                </div>
                <div class="card analysis-card">
                    <h4 style="color: var(--danger); display: flex; align-items: center; gap: 0.5rem; margin-bottom: 0.75rem;">
                        <span>🔴</span> Oportunidade de Melhoria
                    </h4>
                    ${worstDisc ? `
                        <p style="font-size: 0.95rem; font-weight: 600; color: var(--text-primary);">${worstDisc}</p>
                        <p style="font-size: 0.85rem; color: var(--text-secondary); margin-top: 0.25rem;">Aproveitamento de apenas <strong>${worstAcc.toFixed(1)}%</strong>. Sugerimos focar em revisar a teoria básica desta matéria.</p>
                    ` : '<p style="font-size: 0.85rem; color: var(--text-secondary);">Resolva mais questões de cada disciplina para identificar áreas de melhoria.</p>'}
                </div>
            </div>
        `;
    }

    // 4. Slowest questions table
    const slowQuestions = Object.entries(solved)
        .filter(([_, info]) => info.solved)
        .map(([qId, info]) => ({ id: qId, ...info }))
        .sort((a, b) => (b.timeSpent || 0) - (a.timeSpent || 0))
        .slice(0, 5);

    let slowHtml = "";
    if (slowQuestions.length > 0) {
        let rows = slowQuestions.map(item => {
            const qDetails = qMap[item.id] || { discipline: "N/A", number: 0, examId: "" };
            const isCorrectText = item.correct ? '<span style="color: var(--success); font-weight: 600;">✓ Correta</span>' : '<span style="color: var(--danger); font-weight: 600;">✗ Incorreta</span>';
            return `
                <tr>
                    <td>Q${qDetails.number} (${qDetails.discipline})</td>
                    <td>${isCorrectText}</td>
                    <td>Opção (${item.selectedOption})</td>
                    <td style="font-weight: 600;">${item.timeSpent}s</td>
                    <td>
                        <button class="btn btn-secondary btn-sm" onclick="reviewHistoryQuestion('${qDetails.examId}', ${qDetails.number})">Rever</button>
                    </td>
                </tr>
            `;
        }).join("");

        slowHtml = `
            <div class="card analysis-card" style="margin-top: 1.5rem;">
                <h4 style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; color: var(--text-primary);">⏱️ Questões mais demoradas</h4>
                <div class="table-responsive">
                    <table class="analysis-table">
                        <thead>
                            <tr>
                                <th>Questão</th>
                                <th>Resultado</th>
                                <th>Sua Resposta</th>
                                <th>Tempo Gasto</th>
                                <th>Ação</th>
                            </tr>
                        </thead>
                        <tbody>
                            ${rows}
                        </tbody>
                    </table>
                </div>
            </div>
        `;
    }

    // 5. Discipline breakdown table
    let discRows = Object.entries(disciplines)
        .sort((a, b) => (b[1].correct / b[1].total) - (a[1].correct / a[1].total))
        .map(([disc, stat]) => {
            const discAcc = (stat.correct / stat.total * 100);
            const discAvg = (stat.time / stat.total);
            const progressColor = discAcc >= 75 ? 'var(--success)' : (discAcc >= 50 ? 'var(--warning)' : 'var(--danger)');
            
            const dh = Math.floor(stat.time / 3600);
            const dm = Math.floor((stat.time % 3600) / 60);
            const ds = stat.time % 60;
            const dTimeStr = dh > 0 ? `${dh}h ${dm}m ${ds}s` : `${dm}m ${ds}s`;

            return `
                <tr>
                    <td style="font-weight: 600;">${disc}</td>
                    <td style="text-align: center;">${stat.total}</td>
                    <td style="text-align: center; color: var(--success); font-weight: 600;">${stat.correct}</td>
                    <td style="text-align: center; color: var(--danger); font-weight: 600;">${stat.total - stat.correct}</td>
                    <td>
                        <div style="display: flex; align-items: center; gap: 0.85rem;">
                            <div class="progress-bar-container" style="flex-grow: 1; height: 8px;">
                                <div class="progress-bar" style="width: ${discAcc}%; background-color: ${progressColor};"></div>
                            </div>
                            <span style="font-size: 0.85rem; font-weight: 600; min-width: 45px; text-align: right;">${discAcc.toFixed(1)}%</span>
                        </div>
                    </td>
                    <td>${dTimeStr}</td>
                    <td>${discAvg.toFixed(1)}s</td>
                </tr>
            `;
        }).join("");

    let discTableHtml = `
        <div class="card analysis-card" style="margin-top: 1.5rem;">
            <h4 style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; color: var(--text-primary);">📚 Detalhamento por Disciplina</h4>
            <div class="table-responsive">
                <table class="analysis-table">
                    <thead>
                        <tr>
                            <th>Disciplina</th>
                            <th style="text-align: center;">Resolvidas</th>
                            <th style="text-align: center;">Acertos</th>
                            <th style="text-align: center;">Erros</th>
                            <th style="min-width: 180px;">Aproveitamento</th>
                            <th>Tempo Total</th>
                            <th>Tempo Médio</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${discRows}
                    </tbody>
                </table>
            </div>
        </div>
    `;

    // 6. Exam breakdown table
    let examRows = Object.entries(exams)
        .sort((a, b) => (b[1].correct / b[1].total) - (a[1].correct / a[1].total))
        .map(([exId, stat]) => {
            const exAcc = (stat.correct / stat.total * 100);
            const exAvg = (stat.time / stat.total);
            
            const eh = Math.floor(stat.time / 3600);
            const em = Math.floor((stat.time % 3600) / 60);
            const es = stat.time % 60;
            const eTimeStr = eh > 0 ? `${eh}h ${em}m ${es}s` : `${em}m ${es}s`;

            return `
                <tr>
                    <td style="font-weight: 600;">${stat.name} <span class="badge" style="background-color: var(--bg-tertiary); color: var(--text-primary); margin-left: 0.5rem;">${stat.banca}</span></td>
                    <td style="text-align: center;">${stat.total}</td>
                    <td style="text-align: center; color: var(--success); font-weight: 600;">${stat.correct}</td>
                    <td style="text-align: center; color: var(--danger); font-weight: 600;">${stat.total - stat.correct}</td>
                    <td style="font-weight: 600; color: var(--text-primary);">${exAcc.toFixed(1)}%</td>
                    <td>${eTimeStr}</td>
                    <td>${exAvg.toFixed(1)}s</td>
                </tr>
            `;
        }).join("");

    let examTableHtml = `
        <div class="card analysis-card" style="margin-top: 1.5rem;">
            <h4 style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; color: var(--text-primary);">📝 Detalhamento por Concurso</h4>
            <div class="table-responsive">
                <table class="analysis-table">
                    <thead>
                        <tr>
                            <th>Concurso</th>
                            <th style="text-align: center;">Resolvidas</th>
                            <th style="text-align: center;">Acertos</th>
                            <th style="text-align: center;">Erros</th>
                            <th>Aproveitamento</th>
                            <th>Tempo Total</th>
                            <th>Tempo Médio</th>
                        </tr>
                    </thead>
                    <tbody>
                        ${examRows}
                    </tbody>
                </table>
            </div>
        </div>
    `;

    // 7. Interactive error details list
    let errorDetailsHtml = "";
    if (incorrectDetails.length > 0) {
        let errorCards = incorrectDetails.map((err, i) => {
            let stmtText = err.statement.trim();
            if (stmtText.length > 250) {
                stmtText = stmtText.substring(0, 250) + "...";
            }
            return `
                <div class="error-detail-item">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 0.5rem; gap: 1rem; flex-wrap: wrap;">
                        <div>
                            <span class="error-badge">Erro ${i + 1}</span>
                            <span style="font-size: 0.85rem; font-weight: 600; color: var(--text-secondary); margin-left: 0.5rem;">
                                Q${err.number} - ${err.discipline}
                            </span>
                        </div>
                        <button class="btn btn-secondary btn-sm" onclick="reviewHistoryQuestion('${err.examId}', ${err.number})">⚙️ Rever no Praticar</button>
                    </div>
                    <p style="font-size: 0.85rem; color: var(--text-muted); font-style: italic; margin-bottom: 0.5rem;">
                        "${err.examName}"
                    </p>
                    <p class="error-statement-preview">
                        ${stmtText}
                    </p>
                    <div style="margin-top: 0.75rem; display: flex; gap: 1.5rem; font-size: 0.85rem; flex-wrap: wrap;">
                        <span style="color: var(--danger); font-weight: 600;">Sua Resposta: (${err.selected})</span>
                        <span style="color: var(--success); font-weight: 600;">Gabarito: (${err.correctAnswer})</span>
                        <span style="color: var(--text-muted);">Tempo Gasto: ${err.time}s</span>
                    </div>
                </div>
            `;
        }).join("");

        errorDetailsHtml = `
            <div class="card analysis-card" style="margin-top: 1.5rem;">
                <h4 style="margin-bottom: 1rem; display: flex; align-items: center; gap: 0.5rem; color: var(--danger);">
                    ❌ Detalhamento dos Erros (${incorrectDetails.length})
                </h4>
                <p style="font-size: 0.85rem; color: var(--text-secondary); margin-bottom: 1.25rem;">
                    Analise os enunciados das questões incorretas e revise sua linha de raciocínio. Clique em "Rever no Praticar" para responder novamente e visualizar os comentários completos.
                </p>
                <div class="error-details-list">
                    ${errorCards}
                </div>
            </div>
        `;
    }

    // Assemble the container view
    container.innerHTML = `
        <div class="stats-grid">
            <div class="card card-gradient">
                <div class="stat-icon">📈</div>
                <div class="stat-title">Questões Resolvidas</div>
                <div class="stat-value">${totalSolved}</div>
            </div>
            <div class="card card-gradient">
                <div class="stat-icon">🎯</div>
                <div class="stat-title">Taxa de Acerto</div>
                <div class="stat-value">${accuracy.toFixed(1)}%</div>
            </div>
            <div class="card card-gradient">
                <div class="stat-icon">⏱️</div>
                <div class="stat-title">Tempo de Estudo</div>
                <div class="stat-value" style="font-size: 1.5rem; line-height: 1.8rem; margin-top: 0.2rem;">${timeStr}</div>
            </div>
            <div class="card card-gradient">
                <div class="stat-icon">⚡</div>
                <div class="stat-title">Média por Questão</div>
                <div class="stat-value">${avgTime.toFixed(1)}s</div>
            </div>
        </div>

        ${dataprevHtml}
        ${strengthsHtml}
        ${discTableHtml}
        ${examTableHtml}
        ${slowHtml}
        ${errorDetailsHtml}
    `;
}

// Trigger Gemini AI explanation for active question
async function triggerGeminiExplanation(force = false) {
    if (currentQuestions.length === 0) return;
    const q = currentQuestions[currentQuestionIndex];
    const solvedData = userState.solvedQuestions[q.id];
    
    if (!solvedData || !solvedData.solved) {
        alert("Responda à questão antes de solicitar a explicação do Gemini.");
        return;
    }

    const aiExplanationBox = document.getElementById("ai-explanation-box");
    const aiExplanationText = document.getElementById("ai-explanation-text");

    if (aiExplanationBox && aiExplanationText) {
        aiExplanationBox.style.display = "flex";
        
        // If already cached and not forced, just show it
        if (solvedData.aiExplanation && !force) {
            aiExplanationText.innerHTML = solvedData.aiExplanation;
            aiExplanationBox.scrollIntoView({ behavior: 'smooth' });
            return;
        }

        // Show loading state
        aiExplanationText.innerHTML = '<span class="ai-loading-pulse">🤖 O Gemini está analisando a questão... Aguarde alguns instantes.</span>';
        aiExplanationBox.scrollIntoView({ behavior: 'smooth' });

        const apiKey = userState.geminiApiKey || '';
        if (!apiKey) {
            aiExplanationText.innerHTML = '<span style="color: var(--danger);">❌ Chave da API do Gemini não configurada nas Configurações!</span>';
            return;
        }

        try {
            // Construct prompt
            const prompt = `Você é um professor experiente em concursos públicos. Analise a seguinte questão e explique detalhadamente de forma didática:
1) Por que a alternativa correta é a verdadeira.
2) O erro de cada uma das outras alternativas.
3) Preste atenção especial na alternativa que o estudante escolheu (se for diferente da correta), mostrando onde está a pegadinha ou o erro de raciocínio.

DADOS DA QUESTÃO:
- Concurso: ${currentExam.exam_name}
- Disciplina: ${q.discipline}
- Enunciado:
${q.statement}

- Alternativas:
${Object.entries(q.options).map(([k, v]) => `  (${k}) ${v}`).join('\n')}

- Gabarito Oficial (Correta): Alternativa ${q.correct_answer}
- Resposta Escolhida pelo Estudante: Alternativa ${solvedData.selectedOption} (${solvedData.correct ? 'O estudante ACERTOU' : 'O estudante ERROU'})

Escreva a explicação de forma clara, amigável e direta em português. Utilize formatação Markdown (negritos, listas, blocos de citação) para destacar os pontos importantes.`;

            // Call Gemini 3.5 Flash API (v1beta endpoint)
            const url = `https://generativelanguage.googleapis.com/v1beta/models/gemini-3.5-flash:generateContent?key=${apiKey}`;
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify({
                    contents: [{
                        parts: [{
                            text: prompt
                        }]
                    }]
                })
            });

            if (!response.ok) {
                const errData = await response.json();
                console.error("API error details:", errData);
                throw new Error(errData.error?.message || `HTTP ${response.status}`);
            }

            const data = await response.json();
            const text = data.candidates?.[0]?.content?.parts?.[0]?.text;
            
            if (text) {
                // Convert simple Markdown to HTML
                const htmlContent = parseMarkdown(text);
                solvedData.aiExplanation = htmlContent;
                saveState();
                aiExplanationText.innerHTML = htmlContent;
            } else {
                throw new Error("Resposta inválida da API do Gemini.");
            }

        } catch (error) {
            console.error("Gemini AI API Error:", error);
            aiExplanationText.innerHTML = `<span style="color: var(--danger);">❌ Erro ao chamar o Gemini: ${error.message}. Verifique sua chave de API nas Configurações.</span>`;
        }
    }
}

// Convert basic markdown formatting to HTML tags
function parseMarkdown(text) {
    if (!text) return "";
    
    let html = text;
    
    // Replace markdown headers (###, ##, #)
    html = html.replace(/^### (.*$)/gim, '<h5 style="margin-top: 1rem; margin-bottom: 0.5rem; color: var(--accent-primary);">$1</h5>');
    html = html.replace(/^## (.*$)/gim, '<h4 style="margin-top: 1rem; margin-bottom: 0.5rem; color: var(--accent-primary);">$1</h4>');
    html = html.replace(/^# (.*$)/gim, '<h3 style="margin-top: 1.25rem; margin-bottom: 0.75rem; color: var(--accent-primary);">$1</h3>');
    
    // Bold text (**text**)
    html = html.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>');
    
    // Italic text (*text*)
    html = html.replace(/\*(.*?)\*/g, '<em>$1</em>');
    
    // Code blocks/Inline code (`code`)
    html = html.replace(/`(.*?)`/g, '<code style="background-color: var(--bg-primary); padding: 0.15rem 0.3rem; border-radius: 4px; font-family: monospace; font-size: 0.9em; border: 1px solid var(--border-color);">$1</code>');
    
    // Blockquotes (> text)
    html = html.replace(/^\> (.*$)/gim, '<blockquote style="border-left: 3px solid var(--accent-secondary); padding-left: 1rem; color: var(--text-secondary); margin: 0.75rem 0; font-style: italic;">$1</blockquote>');
    
    // Bullet points (- or *)
    html = html.replace(/^\s*[-\*]\s+(.*$)/gim, '<li style="margin-left: 1.5rem; margin-bottom: 0.25rem;">$1</li>');
    
    // Line breaks
    html = html.replace(/\n/g, '<br>');
    
    return html;
}
